# ThreatMap Africa Environment Configuration
# Copy this to .env and fill in real values.
# For developer-specific overrides, create .env.local (gitignored). Values in .env.local override .env.

# Database
POSTGRES_PASSWORD=threatmap_secure_password

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-super-secret-key-at-least-32-chars-long

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:3000

# Optional: Enrichment API keys
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# Supabase (storage + credentials)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=threatmap
