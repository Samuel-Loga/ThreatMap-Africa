# ThreatMap Africa Environment Configuration
# Copy this to .env and fill in real values

# Database
POSTGRES_PASSWORD=threatmap_secure_password

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-super-secret-key-at-least-32-chars-long

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:3000

# Optional: Enrichment API keys
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# MinIO (optional object storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
